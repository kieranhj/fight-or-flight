{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["@cloudflare/workers-types"],
    "skipLibCheck": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "include": [
    "worker/src",
    "src/config/types.ts",
    "src/config/airports.ts",
    "src/config/corridors.ts",
    "src/config/rules.ts",
    "src/config/calendar.ts",
    "src/lib/geo.ts"
  ]
}
